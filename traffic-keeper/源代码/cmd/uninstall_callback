#!/bin/bash
# Traffic Keeper - 卸载回调脚本
# 通过 .env 中的 REMOVE_DATA_ON_UNINSTALL 控制是否删除数据
# 请在 Web 管理界面「系统设置」中配置，卸载前请先保存配置

DATA_DIR="${TRIM_PKGVAR}"
ENV_FILE="${DATA_DIR}/.env"
REMOVE_DATA="false"

# 从 .env 读取配置
if [ -f "$ENV_FILE" ]; then
    val=$(grep -E '^REMOVE_DATA_ON_UNINSTALL=' "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"' | tr -d "'" | tr -d ' ')
    [ "$val" = "true" ] && REMOVE_DATA="true"
fi

echo "=========================================="
echo " Traffic Keeper 卸载"
echo " 数据删除: $REMOVE_DATA"
echo " 数据目录: ${DATA_DIR}"
echo "=========================================="

if [ "$REMOVE_DATA" = "true" ]; then
    rm -rf "${DATA_DIR}"
    echo "✅ Traffic Keeper 已卸载，全部数据已删除"
else
    echo "ℹ️  数据已保留，如需删除请手动执行:"
    echo "   rm -rf ${DATA_DIR}"
fi

exit 0