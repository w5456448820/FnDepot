#!/bin/bash
# Traffic Keeper - 卸载回调脚本
# 彻底终止所有相关进程，数据目录由系统卸载对话框控制

# 终止 traffic-keeper.sh 进程
for pid in $(pgrep -f "traffic-keeper.sh" 2>/dev/null); do
    kill -9 "$pid" 2>/dev/null
    echo "已终止 traffic-keeper.sh PID: $pid"
done

# 终止所有 webserver.py 进程
for pid in $(pgrep -f "webserver.py" 2>/dev/null); do
    kill -9 "$pid" 2>/dev/null
    echo "已终止 webserver.py PID: $pid"
done

# 终止所有 python3 相关进程（保险措施）
for pid in $(pgrep -f "python3.*traffic-keeper" 2>/dev/null); do
    kill -9 "$pid" 2>/dev/null
    echo "已终止 python3 PID: $pid"
done

# 清理 PID 文件
rm -f /var/apps/traffic-keeper/tk.pid
rm -f /var/apps/traffic-keeper/var/app.pid

# 等待进程完全退出
sleep 2

echo "Traffic Keeper 进程已清理完毕"
exit 0