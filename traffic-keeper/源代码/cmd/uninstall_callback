#!/bin/bash
# Traffic Keeper - 卸载回调脚本
# 仅清理运行中的进程，数据目录由系统卸载对话框控制

# 终止 Web 管理服务
PID_FILE="/var/apps/traffic-keeper/tk.pid"
if [ -f "$PID_FILE" ]; then
    PID=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
        kill "$PID" 2>/dev/null
        echo "已终止进程 PID: $PID"
    fi
    rm -f "$PID_FILE"
fi

# 终止残留的 webserver 进程
for pid in $(pgrep -f "python3.*webserver" 2>/dev/null); do
    kill "$pid" 2>/dev/null
    echo "已终止残留进程 PID: $pid"
done

exit 0