#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
PORT_FILE="${TRIM_PKGVAR}/.port"

APP_DIR=""
for d in "${TRIM_PKGVAR}/app" "${TRIM_APPDEST}/server"; do
    if [ -f "${d}/traffic-keeper.sh" ]; then APP_DIR="$d"; break; fi
done
[ -z "$APP_DIR" ] && { echo "$(date) - ERROR: no traffic-keeper.sh" >> "${LOG_FILE}"; exit 1; }

DATA_DIR="${TRIM_PKGVAR}/data"
DISPLAY_DIR="${TRIM_PKGVAR}/流量统计"
ENV_FILE="${TRIM_PKGVAR}/.env"

WEB_PORT="8080"
if [ -f "${PORT_FILE}" ]; then
    WEB_PORT=$(head -n 1 "${PORT_FILE}" | tr -d '[:space:]')
fi

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

start_process() {
    if status; then
        return 0
    fi

    log_msg "Starting Traffic Keeper (port=${WEB_PORT})..."

    export TK_APP_DIR="$APP_DIR"
    export TK_DATA_DIR="$DATA_DIR"
    export TK_DISPLAY_DIR="$DISPLAY_DIR"
    export TK_ENV_FILE="$ENV_FILE"
    export TK_LOG_FILE="$LOG_FILE"
    export TK_PID_DIR="${TRIM_PKGVAR}"
    export TK_WEB_PORT="${WEB_PORT}"
    # 禁止 Python 生成 .pyc 缓存，避免旧缓存导致代码不更新
    export PYTHONDONTWRITEBYTECODE=1

    mkdir -p "$DATA_DIR/links" "$DISPLAY_DIR"
    [ -f "$ENV_FILE" ] || touch "$ENV_FILE"

    # 清理 Python 缓存，确保加载最新代码
    find "${APP_DIR}" -name "*.pyc" -delete 2>/dev/null || true
    find "${APP_DIR}" -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

    # 强制终止所有残留进程（确保端口释放）
    for p in $(pgrep -f "webserver.py" 2>/dev/null); do
        kill -9 "$p" 2>/dev/null
    done
    for p in $(pgrep -f "traffic-keeper.sh" 2>/dev/null); do
        kill -9 "$p" 2>/dev/null
    done
    for p in $(pgrep -f "python3.*traffic-keeper" 2>/dev/null); do
        kill -9 "$p" 2>/dev/null
    done
    sleep 2

    # 检查端口是否仍被占用，强制终止占用进程
    port_pid=$(lsof -ti:${WEB_PORT} 2>/dev/null || ss -tlnp 2>/dev/null | grep ":${WEB_PORT} " | grep -oP 'pid=\K[0-9]+')
    if [ -n "$port_pid" ]; then
        log_msg "端口 ${WEB_PORT} 被 PID ${port_pid} 占用，强制终止"
        kill -9 "$port_pid" 2>/dev/null
        sleep 1
    fi

    bash "${APP_DIR}/traffic-keeper.sh" >> ${LOG_FILE} 2>&1 &
    echo -n "$!" > ${PID_FILE}
    log_msg "traffic-keeper.sh started (PID: $!)"

    sleep 1

    python3 "${APP_DIR}/webserver.py" >> ${LOG_FILE} 2>&1 &
    log_msg "webserver.py started (PID: $!, port: ${WEB_PORT})"

    return 0
}

stop_process() {
    log_msg "Stopping Traffic Keeper..."

    # 强制终止 traffic-keeper.sh（主进程）
    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        log_msg "pid=${pid}"
        if check_process "${pid}"; then
            kill -9 "${pid}" 2>/dev/null
            sleep 1
        fi
        rm -f "${PID_FILE}"
    fi

    # 强制终止所有 webserver.py 进程
    for p in $(pgrep -f "webserver.py" 2>/dev/null); do
        kill -9 "$p" 2>/dev/null
    done

    # 强制终止所有 traffic-keeper.sh 进程
    for p in $(pgrep -f "traffic-keeper.sh" 2>/dev/null); do
        kill -9 "$p" 2>/dev/null
    done

    # 强制终止所有 python3 traffic-keeper 进程
    for p in $(pgrep -f "python3.*traffic-keeper" 2>/dev/null); do
        kill -9 "$p" 2>/dev/null
    done

    # 清理 PID 文件
    rm -f "${TRIM_PKGVAR}/app.pid"

    log_msg "Stopped"
    return 0
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

case $1 in
start)
    start_process
    ;;
stop)
    stop_process
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
